# Environment
NODE_ENV=development
PORT=3000

# Database (SQLite for development)
DATABASE_URL="file:./prisma/dev.db"
# Production example:
# DATABASE_URL="postgresql://user:password@host:5432/agame?schema=public"

# Redis (optional)
REDIS_URL="redis://localhost:6379"

# JWT
JWT_SECRET="change-this-to-a-random-secret-key"
JWT_EXPIRES_IN="24h"

# Game Config
GAME_DAY_DURATION_SECONDS=86400
MAX_PENDING_EVENTS=10
DEFAULT_PLAYER_ATTRIBUTES='{"physique":40,"agility":40,"wisdom":40,"willpower":40,"perception":40,"charisma":40,"fame":0,"infamy":0,"luck":50}'

# LLM API Keys (at least one is required for Chronos Agent)
# Zhipu (GLM-4) - primary cloud provider
ZHIPU_API_KEY=""
# Alibaba (Qwen) - fallback provider
QWEN_API_KEY=""
# Baidu (Ernie) - optional 3rd fallback
ERNIE_API_KEY=""
ERNIE_SECRET_KEY=""

# Local LLM (Ollama / LM Studio / vLLM) - OpenAI-compatible endpoint
LOCAL_API_KEY=""
LOCAL_BASE_URL="http://localhost:11434/v1"
LOCAL_MODEL="llama3"

# ============================================
# Agent Tier Configuration (分层LLM调用)
# 不同层级Agent使用不同provider，控制成本
# ============================================

# L1 - 世界级 (Chronos Agent): 高质量模型
AGENT_TIER_L1_PROVIDER="zhipu"
AGENT_TIER_L1_MODEL="glm-4"

# L2 - 国家层 (Nation Agent): 中端模型
AGENT_TIER_L2_PROVIDER="qwen"
AGENT_TIER_L2_MODEL="qwen-plus"

# L3 - 城邦层 (City Agent): 低成本模型
AGENT_TIER_L3_PROVIDER="local"
AGENT_TIER_L3_MODEL="qwen2.5:7b"

# L4 - NPC层: 最便宜/免费模型
AGENT_TIER_L4_PROVIDER="local"
AGENT_TIER_L4_MODEL="qwen2.5:1.5b"
