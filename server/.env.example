# Environment
NODE_ENV=development
PORT=3000

# Database
DATABASE_URL="postgresql://agame_user:agame_password@localhost:5432/agame?schema=public"

# Redis
REDIS_URL="redis://localhost:6379"

# JWT
JWT_SECRET="your-super-secret-jwt-key-change-in-production"
JWT_EXPIRES_IN="24h"

# Game Config
GAME_DAY_DURATION_SECONDS=86400
MAX_PENDING_EVENTS=10
DEFAULT_PLAYER_ATTRIBUTES='{"physique":40,"agility":40,"wisdom":40,"willpower":40,"perception":40,"charisma":40,"fame":0,"infamy":0,"luck":50}'

# Agent System (optional)
OPENAI_API_KEY=""
AGENT_MODEL="gpt-4"